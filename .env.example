# =============================================================================
# Clinical Voice AI Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ─── AI API Keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://clinic_user:secure_password@mongodb:27017/clinic_db?authSource=admin
MONGODB_DATABASE=clinic_db
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secure_admin_password
MONGO_INITDB_DATABASE=clinic_db
MONGODB_USER=clinic_user
MONGODB_PASSWORD=secure_password

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:secure_redis_password@redis:6379
REDIS_PASSWORD=secure_redis_password

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-here
JWT_EXPIRY=3600

# ─── Encryption (HIPAA) ─────────────────────────────────────────────────────
PHI_ENCRYPTION_KEY=base64-encoded-32-byte-key-here

# ─── Service Configuration ───────────────────────────────────────────────────
LOG_LEVEL=info
TIMEZONE=Asia/Kolkata

# ─── STT Service ─────────────────────────────────────────────────────────────
STT_MODEL=large-v3
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1

# ─── LLM Agent ───────────────────────────────────────────────────────────────
LLM_PRIMARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

# ─── TTS Service ─────────────────────────────────────────────────────────────
TTS_MODEL=xtts_v2
TTS_DEVICE=cpu

# ─── Campaign Engine ─────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=20
CALLING_HOURS_START=09:00
CALLING_HOURS_END=20:00

# ─── Observability ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin_password
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ─── Docker ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=clinic-voice-ai
