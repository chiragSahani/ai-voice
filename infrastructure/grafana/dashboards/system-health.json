{
  "dashboard": {
    "id": null,
    "uid": "system-health",
    "title": "System Health Overview",
    "tags": ["voice-agent", "health"],
    "timezone": "browser",
    "refresh": "15s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Service Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up",
            "legendFormat": "{{ job }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (service)",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "id": 3,
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) by (service)",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "id": 4,
        "title": "HTTP Request Duration P99",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "id": 5,
        "title": "Active Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "active_connections",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Redis Memory Usage",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
            "legendFormat": "Memory Usage"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.7, "color": "yellow" }, { "value": 0.85, "color": "red" }] } } }
      },
      {
        "id": 7,
        "title": "MongoDB Connections",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
        "targets": [
          {
            "expr": "mongodb_connections_current",
            "legendFormat": "Current"
          }
        ]
      },
      {
        "id": 8,
        "title": "Error Rate by Type",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
        "targets": [
          {
            "expr": "sum(rate(errors_total[5m])) by (error_type)",
            "legendFormat": "{{ error_type }}"
          }
        ]
      }
    ]
  }
}
